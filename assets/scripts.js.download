});


/* When documents is resize */
$(window).on('resize',function(event){
    var windowInnerHeight = $(window).innerHeight();
    bannerHeight(windowInnerHeight);
});

function bannerHeight(windowInnerHeight){
    $('.banner.home-page').css('height', windowInnerHeight);
}

// Main slider all functionality including video slider

function mainSlider(){
    if ( rest_of_slide.length ){
        var mainSliderArgs = {
            items: 1,
            dots: false,
            nav: false,
            autoplay: true,
            autoplayTimeout: 10000,
            loop: true,
            animateIn: 'fadeIn',
            animateOut: 'fadeOut',
            responsive: {
                1200: {
                    dots: false,
                    nav: true
                }
            },
            onChanged: function(event){
                var $owlItem = $(event.target).find(".owl-item").eq(event.item.index);
                var $videoEl = $owlItem.find('video');

                if ($videoEl.length) {
                    $(event.target).trigger('stop.owl.autoplay');

                    // Remove src from all videos to reset
                    $("video").each(function() {
                        $(this).removeAttr("src").removeAttr("id").get(0).pause();
                    });

                    var isMobile = window.matchMedia("(max-width: 991px)").matches;
                    var videoSrc = isMobile ? $videoEl.data("link-mobile") : $videoEl.data("link");

                    if (videoSrc) {
                        $videoEl.attr("src", videoSrc);
                        var objectid = $videoEl.data("id");
                        $videoEl.attr("id", "vid-" + objectid);
                        var vid = document.getElementById("vid-" + objectid);
                        vid.play();
                        vid.addEventListener("ended", function() {
                            $(event.target).trigger('play.owl.autoplay');
                        }, { once: true });
                    } else {
                        if (isMobile) {
                            $videoEl.remove();
                        }
                        $(event.target).trigger('play.owl.autoplay');
                    }
                }
            }
        }
        $('.main-banner').html(rest_of_slide).owlCarousel(mainSliderArgs);
    }
}

// All the common js goes here
function commonScripts(){}

function slidrerOnlyMobile(elem, breakpoint, args) {
	
    if ($(elem)[0]) {
        var s = $(elem);
        
        if (window.innerWidth < breakpoint) {
            s.owlCarousel(args)
		} else s.addClass("off"); 
		
        $(window).resize(function (e) {
            if (window.innerWidth < breakpoint) {
                if ($(elem).hasClass("off")) {
                    s.owlCarousel(args);
                    s.removeClass("off")
                }
            } else $(elem).hasClass("off") || (s.addClass("off").trigger("destroy.owl.carousel"), s.find(".owl-stage-outer").children(":eq(0)").unwrap())
        })
    }
}

function mobileExpander(){
    var svgElePlus  = '<svg width="30" height="30" aria-hidden="true"><use xmlns:xlink="//www.w3.org/1999/xlink"  xlink:href="#menu_plus"></use></svg>';
    var svgEleMinus = '<svg width="30" height="30" aria-hidden="true"><use xmlns:xlink="//www.w3.org/1999/xlink"  xlink:href="#menu_minus"></use></svg>';

    // Append .expicon for both #desktop-menu and #mobile-menu
    $('#desktop-menu li.menu-item-has-children, #mobile-menu li.menu-item-has-children').each(function(){
        $(this).find('a').first().after('<div class="expicon">'+svgElePlus+'</div>');
    });

    $('#mobile-menu li.menu-item-has-children').hover(
        function() {
            $(this).addClass('hovered');
        },
        function() {
            $(this).removeClass('hovered');
        }
    );

    $('.hasExpanded').mouseleave(function(){
        $(this).find('.expicon').first().html(svgElePlus);
        $(this).find('.sub-menu').slideUp();
    });

    if (window.matchMedia("(min-width: 1200px)").matches) {
        $("#desktop-menu li, #mobile-menu li").each(function(){
            if($(this).hasClass('menu-item-has-children')){
                $(this).addClass('hasExpanded');
            }
        });

        $('.hasExpanded').mouseenter(function(){
            $(this).find('.expicon').first().html(svgEleMinus);
            $(this).children('.sub-menu').addClass('active');
        });

        $('.hasExpanded').mouseleave(function(){
            $(this).find('.expicon').first().html(svgElePlus);
            $(this).children('.sub-menu').removeClass('active');
        });

    }else{
        $('.menu-item-has-children .expicon').on('click', function(){
            $(this).parent().find('.sub-menu').first().slideToggle();
            $(this).toggleClass('active');
            if($(this).hasClass('active')){
                $(this).html(svgEleMinus);
            }else{
                $(this).html(svgElePlus);
            }
        });
    }
}


// Script for larger screen
if(window.matchMedia("(min-width: 1200px)").matches){}

window.addEventListener('load', () => {
    const videos = document.querySelectorAll('.common-video');

    if (videos.length === 0) {
        // console.error('No video elements found in DOM.');
        return;
    }

    videos.forEach(video => {
        // console.log('Trying to play video:', video);
        video.muted = true;
        const playPromise = video.play();

        if (playPromise !== undefined) {
            playPromise.catch(error => {
                // console.error('Autoplay failed:', error);
            });
        }
    });
});