/*
****************************
* Capability Sync Carousel *
****************************
*/
$(".item-title li").on("click", function() {
    var slideIndex = $(this).data("slide");
    $(".item-title li").removeClass("active");
    $(this).addClass("active");
    $(".capabilities-slider, .service-slider").trigger("to.owl.carousel", [slideIndex, 300]);
});

$('.capabilities-slider, .service-slider').on('changed.owl.carousel', function(event) {
    var currentIndex = event.item.index;
    $(".item-title li").removeClass("active");
    $(".item-title li").eq(currentIndex).addClass("active");
});

//trigger the scroll
var lastScrollTop = 0; 
function scrollAnimation(){
    var st = $(this).scrollTop();
    if (st > lastScrollTop){
        $('.navigation').addClass('to-top');
    } else {
        $('.navigation').removeClass('to-top');
    }
    lastScrollTop = st; 
}

$(window).scroll(function() { 
    currentPoint = $(this).scrollTop();
    if ( currentPoint > 200 ){
        scrollAnimation();
        $('.navigation').addClass('white');
        
    }else{
        $('.navigation').removeClass('white');
    } 
});

/* When documents is ready */
$(document).ready(function(){
    var $mainMenuState = $('#main-menu-state');
    if ($mainMenuState.length) {
        // animate mobile menu
        $mainMenuState.change(function(e) {
            var $menu = $('#main-menu');
            if (this.checked) {
                $menu.hide().slideDown(250, function() { $menu.css('display', ''); });
            } else {
                $menu.show().slideUp(250, function() { $menu.css('display', ''); });
            }
        });
        // hide mobile menu beforeunload
        $(window).on('beforeunload unload', function() {
            if ($mainMenuState[0].checked) {
                $mainMenuState[0].click();
            }
        });
    }

    var windowInnerHeight = $(window).innerHeight();
    $('.main-banner.home-page').css('height', windowInnerHeight);

    /*
    ********************
    * Footer Accordion *
    ********************
    */
    $('.accordion-title').click(function() {
        var content = $(this).next('.accordion-content');
        content.toggleClass('active');
        $(this).toggleClass('active');
    });

    /*
    ***************
    * Purpose Tab *
    ***************
    */
    $('.purpose-tab .tab').click(function () {
        var index = $(this).data('tab-index');

        $('.purpose-tab .tab').removeClass('active');
        $(this).addClass('active');

        $('.purpose-card .card').removeClass('active');
        $('.purpose-card .card[data-slider-index="' + index + '"]').addClass('active');
    });

    /*
    *****************************
    * Banking Service Accordion *
    *****************************
    */
    function setupAccordion(sectionSelector) {
        const section = $(sectionSelector);
        section.find('.item:first .bs-description').addClass('active');
        section.find('.item:first .bs-title').addClass('active');

        section.find('.bs-title').click(function () {
            const isActive = $(this).hasClass('active');

            section.find('.bs-description').removeClass('active');
            section.find('.bs-title').removeClass('active');

            if (!isActive) {
                $(this).addClass('active');
                $(this).next('.bs-description').addClass('active');
            }
        });
    }

    setupAccordion('.comp-banking-service');
    setupAccordion('.faq');

    /*
    **************
    * Form Label *
    **************
    */
    $('.input-wrapper input, .input-wrapper select').each(function() {
        var $input = $(this);
        var $label = $input.closest('.input-wrapper').find('label');

        function toggleLabel() {
            if ($input.val().trim() !== '' || $input.is(':focus')) {
                $label.addClass('floating');
            } else {
                $label.removeClass('floating');
            }
        }

        toggleLabel(); // Initial check
        $input.on('focus blur input change', toggleLabel); // Run on events

        // Re-check a little later to catch autofill
        setTimeout(toggleLabel, 500);
    });

    /*
    ***********************
    * Evolution Component *
    ***********************
    */
    $('.evo-slider').removeClass('active').eq(0).addClass('active');
    $('.evo-tabs .item').removeClass('active').eq(0).addClass('active');

    $('.evo-tabs .item').on('click', function () {
        var id = $(this).data('id');

        // Toggle tab active state
        $('.evo-tabs .item').removeClass('active');
        $(this).addClass('active');

        // Toggle active slider
        $('.evo-slider').removeClass('active');
        $('.evo-slider[data-id="' + id + '"]').addClass('active');
    });

    /*
    **********************
    * Location Accordion *
    **********************
    */
    const firstHeader = $('.accordion-header').first();
    const firstContent = firstHeader.next('.accordion-content');
    firstHeader.addClass('active');
    firstContent.slideDown();
    
    $('.accordion-header').on('click', function() {
        var content = $(this).next('.accordion-content');
        
        $('.accordion-content').not(content).slideUp().removeClass('active');
        $('.accordion-header').not(this).removeClass('active');
        
        $(this).toggleClass('active');
        content.slideToggle().toggleClass('active');
    });

    /*
    ************
    * Team Tab *
    ************
    */
    $('.team-tab').on('click', function() {
        var tabID = $(this).data('tab');

        // Set active tab
        $('.team-tab').removeClass('active');
        $(this).addClass('active');

        // Show related content
        $('.team-tab-content').removeClass('active');
        $('.team-tab-content[data-tab="' + tabID + '"]').addClass('active');
    });

    /*
    **************
    * Team popup *
    **************
    */
    $('.card .popup-open').on('click', function(e) {
        e.preventDefault();
        $('.card .popup').removeClass('show');
        $(this).closest('.card').find('.popup').addClass('show');
        $('body').addClass('popup-active');
    });

    $(document).on('click', function(e) {
        if ($(e.target).closest('.popup, .popup-open').length === 0) {
            $('.popup').removeClass('show');
            $('body').removeClass('popup-active');
        }
    });

    $(document).on('keydown', function(e) {
        if (e.key === "Escape") {
            $('.popup').removeClass('show');
            $('body').removeClass('popup-active');
        }
    });

    $('.popup-close').on('click', function() {
        $(this).closest('.popup').removeClass('show');
        $('body').removeClass('popup-active');
    });

    /*
    *******************
    Newsletter Fucntion
    *******************
    */
    // $('#newsletter-subscription').on('submit', function(e){
    //     e.preventDefault();
    //     $('#newsletter-email').removeClass('error');
    //     $('.newsletter-response').html('');
    //     var newsletterEmail = $('#newsletter-email').val();
        
    //     if ( newsletterEmail == '' ){
    //         $('#newsletter-email').addClass('error');
    //         return;
    //     }
        
    //     $('.newsletter-loader').fadeIn();
        
    //     $.ajax({
    //         type: 'POST',
